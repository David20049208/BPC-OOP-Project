<Window x:Class="InventoryApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Správa skladu" Height="900" Width="1200">

	<Grid Margin="15">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<Grid Grid.Row="0" Margin="0 0 0 0" VerticalAlignment="Top">
			<Grid.ColumnDefinitions>	
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Top">
				<TextBox x:Name="NameTextBox" Width="180" Margin="0 0 8 0"
                         Text="Název" Tag="Název" Foreground="Gray"
                         GotFocus="Placeholder_GotFocus" LostFocus="Placeholder_LostFocus"/>

				<TextBox x:Name="PriceTextBox" Width="100" Margin="0 0 8 0"
                         Text="Cena" Tag="Cena" Foreground="Gray"
                         GotFocus="Placeholder_GotFocus" LostFocus="Placeholder_LostFocus"/>

				<TextBox x:Name="QuantityTextBox" Width="100" Margin="0 0 8 0"
                         Text="Množství" Tag="Množství" Foreground="Gray"
                         GotFocus="Placeholder_GotFocus" LostFocus="Placeholder_LostFocus"/>

				<TextBox x:Name="MinStockTextBox" Width="100" Margin="0 0 8 0"
                         Text="Minimum" Tag="Minimum" Foreground="Gray"
                         GotFocus="Placeholder_GotFocus" LostFocus="Placeholder_LostFocus"/>

				<Button Content="Přidat" Width="100" Click="AddButton_Click"/>
			</StackPanel>

			<TextBlock x:Name="StatusTextBlock"
                       Grid.Column="1"
                       Margin="50 -35 0 0"
                       VerticalAlignment="Center"
                       FontWeight="Bold"/>

			<StackPanel Grid.Column="3"
                        HorizontalAlignment="Right"
						VerticalAlignment="Top"
						TextBlock.TextAlignment="Right">

				<TextBlock x:Name="TotalValueTextBlock"
                           FontWeight="Bold"
                           Text="Celkem: 0 Kč"/>

				<TextBlock x:Name="TotalItemCountTextBlock"
                           Margin="0 4 0 0"
                           Text="Kusů celkem: 0"/>

				<TextBlock x:Name="LowStockCountTextBlock"
                           Margin="0 4 0 0"
                           Text="Pod minimem: 0"/>
			</StackPanel>
		</Grid>

		<StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 -20 0 10">
			<TextBox x:Name="SearchTextBox" Width="250" Margin="0 0 8 0"
                     Text="Vyhledat podle názvu" Tag="Vyhledat podle názvu"
                     Foreground="Gray"
                     GotFocus="Placeholder_GotFocus" LostFocus="Placeholder_LostFocus"/>

			<Button Content="Vyhledat" Width="100" Margin="0 0 8 0" Click="SearchButton_Click"/>
			<Button Content="Zobrazit vše" Width="100" Margin="0 0 8 0" Click="ShowAllButton_Click"/>
			<Button Content="Pod minimem" Width="120" Margin="0 0 8 0" Click="LowStockButton_Click"/>
			<Button Content="Upravit vybranou" Width="130" Margin="0 0 8 0" Click="UpdateButton_Click"/>
			<Button Content="Smazat" Width="90" Click="DeleteButton_Click"/>
		</StackPanel>

		<DataGrid x:Name="ItemsDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
			<DataGrid.Columns>
				<DataGridTextColumn Header="Název" Binding="{Binding Name}" Width="*"/>
				<DataGridTextColumn Header="Cena" Binding="{Binding Price}" Width="100"/>
				<DataGridTextColumn Header="Množství" Binding="{Binding Quantity}" Width="100"/>
				<DataGridTextColumn Header="Minimum" Binding="{Binding MinStock}" Width="100"/>
				<DataGridTextColumn Header="Vytvořeno"
                    Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                    Width="160"/>
				<DataGridTextColumn Header="Upraveno"
                    Binding="{Binding UpdatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                    Width="160"/>
			</DataGrid.Columns>
		</DataGrid>

	</Grid>
</Window>